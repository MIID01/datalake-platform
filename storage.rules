rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // CEO can read everything
    function isCeo() {
      return request.auth != null && request.auth.token.email == "m.alqumri@datalake.sa";
    }

    // The caller's RBAC user record (keyed by uid in Firestore).
    function userData() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }
    function isHr() {
      return request.auth != null &&
        (request.auth.token.email == "hr@datalake.sa" || userData().role_id == "hr");
    }

    match /expenses/{fileName} {
      // Engineers can upload and read their own receipts. CEO can read all.
      allow read: if request.auth != null; 
      allow create: if request.auth != null;
      allow update, delete: if isCeo();
    }

    match /employee-photos/{fileName} {
      // Profile photos are stored as "{employee_id}.{ext}". Any signed-in user
      // may VIEW them, but only the owning employee (whose employee_id prefixes
      // the filename) — or CEO/HR — may upload/replace/delete one.
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && (
        isCeo() || isHr() ||
        fileName.split('.')[0] == userData().employee_id
      );
      allow delete: if isCeo() || isHr() ||
        (request.auth != null && fileName.split('.')[0] == userData().employee_id);
    }

    match /client-logos/{fileName} {
      // Client logos shown on timesheets / invoices. Stored as "{clientId}.{ext}".
      // Any signed-in user may view; CRM team (business/sales) + HR + CEO may upload.
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && (
        isCeo() || isHr() ||
        userData().role_id == "business" || userData().role_id == "sales"
      );
    }

    match /datalake-worm-hr/employee_documents/{fileName} {
      // WORM: write-once. No client delete/overwrite — not even the CEO. Lawful
      // disposal of WORM content happens only Admin-side under a retention policy
      // (a CEO-deletable bucket is not WORM). True immutability is the bucket-level
      // GCS retention policy (see scripts/set-worm-retention.sh) — this rule is the
      // client-SDK boundary on top of it.
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Approval-evidence uploads — the signature image is now written by the
    // recordApproval Cloud Function (Admin SDK, which bypasses these rules); the
    // signed document goes to the WORM bucket. No client write path remains. Reads
    // stay open to any signed-in user (SignedBadge thumbnails + audit export).
    match /approval-evidence/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read: if isCeo();
      allow write: if false;
    }
  }
}
