rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isCeoOrCto() {
      // CTO role is VACANT — the CEO acts as CTO. The dormant cto@datalake.sa
      // hardcoded identity was removed (no such account should exist). A real CTO,
      // if ever hired, would be granted via users.role_id == "cto" (RBAC), not a
      // hardcoded email.
      return request.auth != null && request.auth.token.email == "m.alqumri@datalake.sa";
    }
    
    function isCeo() {
      return request.auth != null && request.auth.token.email == "m.alqumri@datalake.sa";
    }

    function getUserRole() {
      return isCeo() ? "ceo" :
             (request.auth != null && (request.auth.token.email == "hr@datalake.sa" || request.auth.token.email == "HR@datalake.sa")) ? "hr" :
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role_id;
    }

    function isAssignedClient(clientId) {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.client_id == clientId;
    }

    // Role helpers. These match getUserRole()'s precedence (hardcoded HR
    // email → role_id from users doc). Used for the segregation-of-duties
    // rules on payroll, approval evidence, etc.
    function isHR() {
      return request.auth != null && (
        request.auth.token.email == "hr@datalake.sa" ||
        request.auth.token.email == "HR@datalake.sa" ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role_id == "hr"
      );
    }
    function isFinance() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role_id == "finance";
    }
    function isBusinessOrSales() {
      return request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role_id == "business" ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role_id == "sales"
      );
    }
    
    // ── RBAC Collections ──
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create, delete: if isCeo();
      // Only the CEO assigns roles — but CANNOT change their OWN role (segregation of duties).
      allow update: if isCeo() && (request.auth.uid != uid || request.resource.data.role_id == resource.data.role_id);
      // Employees may flip ONLY their own onboarding flags on their own user doc.
      // We match by Firebase Auth uid OR by email — legacy users docs are keyed by
      // employee_id (DLSA1003 etc) rather than uid, and the Onboarding flow looks
      // them up via the email fallback.
      allow update: if request.auth != null
        && (request.auth.uid == uid || request.auth.token.email == resource.data.email)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['onboarding_complete', 'onboarding_completed_at', 'pdpl_consent_state', 'pdpl_consent_at', 'pdpl_consent_ip', 'pdpl_consent_user_agent', 'training_completed', 'contract_signed', 'saved_signature', 'saved_signature_at']);
    }

    // ── Hire Chain ──
    match /pending_hires/{hireId} {
      // Reads allowed for any signed-in user, OR public token-gated read
      // when the hire still has an unconsumed client_hire_token (so the
      // /client/approve-hire/:token public page can render).
      allow read: if request.auth != null;
      allow read: if resource.data.client_hire_token != null;
      allow create, delete: if isCeo();
      // CEO can edit anything. Public client-PM token flow may set ONLY the
      // acknowledge/dispute audit fields if the hire still has a token.
      allow update: if isCeo();
      allow update: if resource.data.client_hire_token != null &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'client_acknowledged_at', 'client_acknowledged_by',
          'client_disputed_at', 'client_disputed_by',
          'client_action_ip', 'client_signature_method',
          'client_signature_image', 'client_signature_typed',
          'client_dispute_reason',
        ]);

      // Approval evidence subcollection — anyone signed in may write theirs;
      // the public client-PM token flow may also append an evidence row.
      // Append-only: never editable or deletable once written (immutable record).
      match /approval_evidence/{evId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow create: if request.resource.data.token_used != null;
        allow update, delete: if false;
      }
    }

    // Token-gated client acknowledgement of a hire placement. Anyone with the
    // (cryptographically random) token URL may read it once; only CEO/HR
    // create/delete. The token is burned (deleted) by the client page on
    // submit, which is the only mutation we allow from unauthenticated users.
    match /client_hire_tokens/{token} {
      allow read: if true;
      allow create: if isCeo() || (request.auth != null && getUserRole() == "hr");
      allow delete: if true; // burn-after-use; safe because token is opaque
      allow update: if false;
    }

    // ── IT Administration (it_admin only) — segregated from role assignment ──
    match /admin_credentials/{docId} {
      allow read, write: if request.auth != null && getUserRole() == "it_admin";
    }
    match /password_policies/{docId} {
      // CEO + it_admin can READ (the Credentials page shows expiry/force_reset
      // state). WRITES go through the setpasswordchangerequired / adminsetpassword
      // Cloud Functions on the Admin SDK (which bypass these rules), so no client
      // write is granted here beyond it_admin (kept for any legacy direct write).
      allow read: if request.auth != null && (getUserRole() == "it_admin" || isCeo());
      allow write: if request.auth != null && getUserRole() == "it_admin";
    }
    match /roles/{roleId} {
      allow read: if request.auth != null;
      allow write: if isCeo();
    }
    match /access_matrix/{roleId} {
      allow read: if request.auth != null;
      allow write: if isCeo();
    }
    match /clients/{clientId} {
      // CEO sees all. Business/sales (CRM portal) read+write all client
      // metadata + status/pipeline_stage. A logged-in `client` user reads
      // only the client doc they're scoped to (kept from prior rule).
      allow read: if request.auth != null && (isCeo() || isBusinessOrSales() || isAssignedClient(clientId));
      allow write: if isCeo() || isBusinessOrSales();

      // Per-client notes timeline (CRM detail page Add Note). Same audience
      // as the parent doc; rows are append-only to preserve the interaction
      // log.
      match /client_notes/{noteId} {
        allow read: if isCeo() || isBusinessOrSales();
        allow create: if isCeo() || isBusinessOrSales();
        allow update, delete: if false;
      }
    }

    // ── CRM deals (opportunities) ──
    // `deals` = canonical opportunity (references a client via client_id; never
    // copies account facts). Same audience as clients/client_notes: CEO + the
    // business/sales CRM roles. deal_activities is an append-only timeline.
    match /deals/{dealId} {
      allow read:   if isCeo() || isBusinessOrSales();
      allow create: if isCeo() || isBusinessOrSales();
      allow update: if isCeo() || isBusinessOrSales();
      allow delete: if isCeo();

      match /deal_activities/{actId} {
        allow read:   if isCeo() || isBusinessOrSales();
        allow create: if isCeo() || isBusinessOrSales();
        allow update, delete: if false; // immutable audit trail
      }
    }

    // ── CRM tasks (crm_tasks) — actionable follow-ups for the sales team ──
    // Canonical task store (deal_activities only logged TASKs). CRM team + CEO.
    match /crm_tasks/{taskId} {
      allow read:   if isCeo() || isBusinessOrSales();
      allow create: if isCeo() || isBusinessOrSales();
      allow update: if isCeo() || isBusinessOrSales();
      allow delete: if isCeo() || isBusinessOrSales();
    }

    // ── CRM agent (DTLK-AI-AGENT-001) — Stuck-Deal Follow-up assistant ──
    // The agent ONLY proposes; the human-review queue + audit are written by Cloud
    // Functions on the Admin SDK. No client SDK path may create/flip a proposal or
    // forge an audit row — that is the entire trust boundary. CEO/business read-only.
    match /agent_runs/{runId} {
      allow read:  if isCeo() || isBusinessOrSales();
      allow write: if false; // runFollowupAgent (Admin SDK) only
    }
    match /agent_proposals/{propId} {
      allow read:  if isCeo() || isBusinessOrSales();
      allow write: if false; // runFollowupAgent proposes, approveAgentProposal decides (Admin SDK)
    }
    match /agent_action_log/{logId} {
      allow read:  if isCeo() || isBusinessOrSales();
      allow write: if false; // append-only audit — server-side only
    }

    // ── GRC Compliance Agent (DTLK-GRC-AI-001) ──
    // Same trust boundary as the CRM agent: all writes are Admin-SDK-only. The agent
    // PROPOSES (grc_proposals); approveGrcProposal (Admin SDK) is the only path a
    // proposal applies. grc_readiness is a server-computed snapshot. Read = CEO or
    // compliance_lead (the GRC surfaces). grc_documents.extracted_text is never
    // exposed to the client SDK (grc_documents has no read rule → default-deny).
    match /grc_agent_runs/{runId} {
      allow read:  if isCeo() || getUserRole() == "compliance_lead";
      allow write: if false;
    }
    match /grc_proposals/{propId} {
      allow read:  if isCeo() || getUserRole() == "compliance_lead";
      allow write: if false;
    }
    match /grc_action_log/{logId} {
      allow read:  if isCeo() || getUserRole() == "compliance_lead";
      allow write: if false;
    }
    match /grc_readiness/{docId} {
      allow read:  if isCeo() || getUserRole() == "compliance_lead";
      allow write: if false;
    }
    // RAG index — chunk text + embeddings. Server-side (Admin SDK) only; the agent
    // reads it inside the Cloud Function and returns access-filtered results. No
    // client SDK path (would bypass the classification filter).
    match /grc_doc_chunks/{chunkId} {
      allow read, write: if false;
    }

    // ── Client project timesheets (monthly grid; DTLK-HR-TS-002) ──
    // Rows=roles, cols=days. Compiled by CRM/HR, reviewed by CTO/CEO (where labeled
    // additional-billable items are added), then client-signed. CEO-only delete.
    match /project_timesheets/{tsId} {
      // CTO owns this; CEO overrides (CTO vacant). HR is OUT of the timesheet flow
      // (CEO directive 2026-06-21). State transitions (assemble / CTO-sign / send /
      // client-sign) all run via Cloud Functions (Admin SDK, bypass rules); the only
      // client-SDK write is the CTO/CEO editing additional-billable on a draft.
      // Owning client can READ their own (to review/sign in the portal); not write.
      allow read:   if isCeoOrCto() || isBusinessOrSales() || isAssignedClient(resource.data.client_id);
      allow create: if isCeoOrCto() || isBusinessOrSales();
      allow update: if isCeoOrCto();
      allow delete: if isCeo();

      // Signature/approval evidence — written ONLY by the (cto)signProjectTimesheet
      // Cloud Functions (Admin SDK, bypasses rules). Immutable + read-restricted.
      match /approval_evidence/{evId} {
        allow read:  if isCeoOrCto() || isBusinessOrSales();
        allow write: if false;
      }
    }

    // ── CRM config (editable lists: public holidays, etc.) ──
    match /crm_config/{docId} {
      allow read:  if request.auth != null;
      allow write: if isCeo() || isBusinessOrSales() || isHR();
    }

    // ── Recruiting campaigns (multi-channel: LinkedIn, Google Ads, …) ──
    // HR/CEO manage; applicants attribute via campaign_id carried on the careers link.
    match /recruiting_campaigns/{campId} {
      allow read, write: if isCeo() || isHR();
    }

    // ── CRM quotes (deal_quotes) — quote/discount approval ──
    // State machine: DRAFT → PENDING_FINANCE → PENDING_CEO → APPROVED (+ REJECTED).
    // Sales (business/sales) + CEO may CREATE a DRAFT and edit it WHILE DRAFT, and
    // may submit DRAFT → PENDING_FINANCE. EVERY transition into PENDING_CEO,
    // APPROVED, or REJECTED is denied here and performed ONLY by the
    // financeReviewDealQuote / approveDealQuote Cloud Functions on the Admin SDK
    // (which bypass these rules) — so no client can write an approved/forwarded
    // state directly. Finance can read (to review) but reviews via the function.
    match /deal_quotes/{quoteId} {
      allow read:   if isCeo() || isBusinessOrSales() || isFinance();
      allow create: if (isCeo() || isBusinessOrSales())
                    && request.resource.data.status == 'DRAFT';
      allow update: if (isCeo() || isBusinessOrSales())
                    && resource.data.status == 'DRAFT'
                    && (request.resource.data.status == 'DRAFT'
                        || request.resource.data.status == 'PENDING_FINANCE');
      allow delete: if isCeo();

      // Immutable evidence — written server-side (Admin SDK) only.
      match /approval_evidence/{evId} {
        allow read: if isCeo() || isBusinessOrSales() || isFinance();
        allow create, update, delete: if false;
      }
    }

    // ── Employees & HR ──
    match /employees/{docId} {
      // PII (incl. salary fields): staff (CEO/HR/finance/CTO) read all; an employee
      // reads only their own record. NOT "any authenticated user" (that exposed all
      // employee PII to every signed-in account, including external client users).
      allow read: if isCeo() || isHR() || isFinance() || getUserRole() == "cto" ||
        (request.auth != null && request.auth.token.email == resource.data.email);
      allow create: if request.auth != null && (getUserRole() == "ceo" || getUserRole() == "hr");
      // CEO/HR may update any field. The employee who owns the record (matched by email)
      // may edit ONLY their own limited self-service fields.
      allow update: if request.auth != null && (
        getUserRole() == "ceo" || getUserRole() == "hr" ||
        (request.auth.token.email == resource.data.email &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['phone', 'emergency_contact', 'photo_url', 'skills', 'certifications', 'updated_at', 'onboarding_complete', 'onboarding_completed_at', 'pdpl_consent_state', 'pdpl_consent_at']))
      );
      allow delete: if request.auth != null && (getUserRole() == "ceo" || (getUserRole() == "hr" && resource.data.employment_status == "PENDING_APPROVAL"));

      // Onboarding acknowledgments: an employee writes their own ack docs
      // (each stamped with their email; reads allowed for any signed-in user / HR/CEO).
      match /onboarding/{itemId} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null
          && request.resource.data.employee_email == request.auth.token.email;
      }
      match /onboarding_evidence/{policyId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
      }
    }
    match /talent_pool/{candidateId} {
      allow read, write: if isCeo() || (request.auth != null && getUserRole() == "hr");
    }
    match /job_listings/{jobId} {
      allow read: if true;
      allow write: if isCeo() || (request.auth != null && getUserRole() == "hr");
    }
    match /employee_documents/{docId} {
      // PDPL: an employee may read ONLY their own documents (passport, medical,
      // etc.); HR and the CEO may read everyone's (the HR document repository).
      allow read: if request.auth != null && (
        getUserRole() == "hr" || isCeo() ||
        (resource.data.engineer_email is string &&
         resource.data.engineer_email.lower() == request.auth.token.email.lower())
      );
      // Create: self-upload of your own doc, or HR/CEO uploading for an engineer.
      allow create: if request.auth != null && (
        getUserRole() == "hr" || isCeo() ||
        (request.resource.data.engineer_email is string &&
         request.resource.data.engineer_email.lower() == request.auth.token.email.lower())
      );
      // Update: owner (e.g. acknowledge their own) or HR/CEO. Delete: HR/CEO only.
      allow update: if request.auth != null && (
        getUserRole() == "hr" || isCeo() ||
        (resource.data.engineer_email is string &&
         resource.data.engineer_email.lower() == request.auth.token.email.lower())
      );
      allow delete: if request.auth != null && (getUserRole() == "hr" || isCeo());
    }
    match /document_requests/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (getUserRole() == "ceo" || getUserRole() == "hr");
    }
    match /training_modules/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (getUserRole() == "ceo" || getUserRole() == "hr");
    }
    match /training_completions/{docId} {
      allow read, write: if request.auth != null;
    }
    match /leave_requests/{docId} {
      // Owner (engineer), the assigned client-PM approver, and HR/CEO. 4-party
      // approval chain writes status directly, so update stays open to those parties.
      allow read: if isCeo() || isHR() ||
        (request.auth != null && (resource.data.engineer_email == request.auth.token.email || resource.data.client_pm_email == request.auth.token.email));
      allow create: if request.auth != null && request.resource.data.engineer_email == request.auth.token.email;
      allow update: if isCeo() || isHR() ||
        (request.auth != null && (resource.data.engineer_email == request.auth.token.email || resource.data.client_pm_email == request.auth.token.email));
      allow delete: if isCeo() || isHR() || (request.auth != null && resource.data.engineer_email == request.auth.token.email);
    }
    match /leave_balances/{docId} {
      // Doc id == engineer_email. Owner reads own; HR/finance/CEO read all; HR/CEO write.
      allow read: if isCeo() || isHR() || isFinance() ||
        (request.auth != null && docId == request.auth.token.email);
      allow write: if isCeo() || isHR();
    }
    match /expenses/{docId} {
      // Owner creates own; owner + finance/CEO read; CEO/finance approve (update).
      allow read: if isCeo() || isFinance() || isHR() ||
        (request.auth != null && resource.data.engineer_email == request.auth.token.email);
      allow create: if request.auth != null && request.resource.data.engineer_email == request.auth.token.email;
      allow update: if isCeo() || isFinance();
      allow delete: if isCeo() || isFinance() || (request.auth != null && resource.data.engineer_email == request.auth.token.email);
    }
    match /travel_requests/{docId} {
      // Owner self-service; staff manage.
      allow read: if isCeo() || isHR() || isFinance() ||
        (request.auth != null && resource.data.engineer_email == request.auth.token.email);
      allow create: if request.auth != null && request.resource.data.engineer_email == request.auth.token.email;
      allow update, delete: if isCeo() || isHR() || isFinance() ||
        (request.auth != null && resource.data.engineer_email == request.auth.token.email);
    }

    // ── Projects & Timesheets ──
    match /projects/{projectId} {
      allow read: if request.auth != null;
      allow write: if isCeoOrCto();

      // Approval evidence (e.g. SAMA materiality sign-off) — written server-side
      // only (recordApproval / Admin SDK).
      match /approval_evidence/{evId} {
        allow read: if request.auth != null;
        allow create, update, delete: if false;
      }
    }
    match /client_projects/{projectId} {
      allow read: if request.auth != null;
      allow write: if isCeoOrCto();

      match /approval_evidence/{evId} {
        allow read: if request.auth != null;
        allow create, update, delete: if false;
      }
    }
    match /engineer_project_assignments/{assignmentId} {
      allow read: if request.auth != null;
      allow write: if isCeoOrCto();
    }
    match /timesheets/{timesheetId} {
      // PDPL/confidentiality: staff (CEO/CTO/HR/finance/CRM) read all; an engineer
      // reads only their own (engineer_email); a client reads only those they
      // approve (client_approver_email). No blanket all-authed read — that let any
      // client see every other client's engineers, hours and rates.
      allow read: if request.auth != null && (
        isCeo()
        || getUserRole() == "cto" || getUserRole() == "hr" || getUserRole() == "finance"
        || getUserRole() == "business" || getUserRole() == "sales"
        || resource.data.engineer_email == request.auth.token.email
        || resource.data.client_approver_email == request.auth.token.email
      );
      allow create: if request.auth != null;
      allow delete: if isCeo();
      // CLIENT_SIGNED is the client's INDEPENDENT attestation — produced ONLY by
      // the token/session sign functions on the Admin SDK (which bypass these
      // rules). No client-SDK path, not even CEO/CTO, may transition a timesheet
      // INTO CLIENT_SIGNED, so it can't be forged. All staff transitions (submit,
      // CTO-approve, reject) already run through Cloud Functions and are unaffected.
      allow update: if isCeoOrCto()
        && !(resource.data.state != 'CLIENT_SIGNED' && request.resource.data.state == 'CLIENT_SIGNED');

      // Immutable approval snapshot rows (written server-side by ctoApproveTimesheet
      // via the Admin SDK, which bypasses these rules). Readable by any signed-in
      // user for audit; never client-mutable — this is the regulator-facing record.
      match /approval_evidence/{evId} {
        allow read: if request.auth != null;
        allow create: if isCeoOrCto();
        allow update, delete: if false;
      }
    }

    // ── Finance & Operations ──
    match /invoices/{docId} {
      // SoD: invoices are READ-ONLY to clients. Every mutation (create via
      // generateInvoice, status flip via ceoApproveInvoice, PAID via the Zoho
      // webhook, Zoho/ZATCA stamps) runs in Cloud Functions on the Admin SDK,
      // which bypasses these rules. No client can flip an invoice's status itself.
      allow read: if request.auth != null;
      allow write: if false;

      // Approval evidence — written server-side only (Admin SDK).
      match /approval_evidence/{evId} {
        allow read: if request.auth != null;
        allow create, update, delete: if false;
      }
    }
    match /client_invoices/{docId} {
      allow read, write: if request.auth != null;
    }
    match /finance_notifications/{notifId} {
      allow read, write: if request.auth != null;
    }
    match /contracts/{docId} {
      allow read: if request.auth != null;
      // HR may create/edit a contract and Legal may REJECT it (LEGAL_REJECTED), but
      // the SIGNED/APPROVED state — status 'ACTIVE' or legal_status 'LEGAL_APPROVED' —
      // is written ONLY by the recordApproval Cloud Function (Admin SDK, which bypasses
      // these rules). No client may transition a contract INTO those states, so an
      // approved contract can never be forged client-side.
      allow create: if request.auth != null && request.resource.data.status != 'ACTIVE';
      allow update: if request.auth != null
        && !(resource.data.status != 'ACTIVE' && request.resource.data.status == 'ACTIVE')
        && !(resource.data.get('legal_status', '') != 'LEGAL_APPROVED' && request.resource.data.get('legal_status', '') == 'LEGAL_APPROVED');
      allow delete: if request.auth != null;

      // Approval evidence — written ONLY server-side by recordApproval (Admin SDK),
      // which also handles the external-counsel token flow. No client create.
      match /approval_evidence/{evId} {
        allow read: if request.auth != null;
        allow create, update, delete: if false;
      }
    }
    // AI auditor proposal/contract review trail (written server-side; CEO-managed).
    match /proposal_reviews/{docId} {
      allow read: if request.auth != null;
      allow write: if isCeo();
    }

    // ── Operations & Support ──
    match /tasks/{taskId} {
      // Tasks are created server-side (createTask CF, Admin SDK). CEO consumes them
      // in TaskInbox; the named assignee may read/act on their own.
      allow read: if isCeo() ||
        (request.auth != null && resource.data.assigned_to_id == request.auth.token.email);
      allow create: if isCeo();
      allow update: if isCeo() ||
        (request.auth != null && resource.data.assigned_to_id == request.auth.token.email);
      allow delete: if isCeo();
    }
    match /task_audit_log/{logId} {
      // Append-only audit trail: any authenticated user (and the Admin SDK in
      // Cloud Functions) may CREATE rows, but no one may ever modify or delete
      // them — so the trail is tamper-evident, matching the "append-only,
      // immutable" claim shown in the UI.
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }
    match /support_tickets/{docId} {
      // Owner raises + replies on own ticket; HR/CEO read all; CEO manages.
      allow read: if isCeo() || isHR() ||
        (request.auth != null && resource.data.engineer_email == request.auth.token.email);
      allow create: if request.auth != null && request.resource.data.engineer_email == request.auth.token.email;
      allow update: if isCeo() ||
        (request.auth != null && resource.data.engineer_email == request.auth.token.email);
      allow delete: if isCeo();
    }
    match /pending_approvals/{docId} {
      // SoD Hub queue: rows are created by generateInvoice and cleared by
      // ceoApproveInvoice (both Admin SDK). Read-only to clients so the queue
      // can't be emptied without the CEO actually approving via the function.
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /evaluations/{evalId} {
      // Immutable hiring scorecards — written only by submitHRScore (Admin SDK).
      allow read: if isCeo() || isHR();
      allow create, update, delete: if false;
    }
    match /audit_log/{logId} {
      // Audit trail — written only server-side (Admin SDK). No client writes (a
      // client-writable audit log is not tamper-evident). Read restricted to staff.
      allow read: if isCeo() || isHR() || isFinance();
      allow create, update, delete: if false;
    }
    match /client_profile/{docId} {
      allow read: if true;
      allow write: if isCeo();
    }

    // ── Engineer specific collections ──
    match /engineer_dashboard/{docId} {
      allow read, write: if request.auth != null;
    }
    match /engineer_actions/{docId} {
      allow read, write: if request.auth != null;
    }

    // ── Platform settings (SAMA criteria, finance_integrations, etc.) ──
    // Read for any signed-in user (components load criteria / toggles on
    // every mount). Writes are CEO-only.
    match /platform_settings/{docId} {
      allow read: if request.auth != null;
      allow write: if isCeo();
    }

    // ── HR email log ──
    // Read for HR / Finance / CEO (audit + send-history view). Writes go
    // through the sendHrEmail Cloud Function, never the client — direct
    // creates are blocked so the log can't be forged or amended.
    match /email_log/{logId} {
      allow read: if isCeo() || isFinance() || isHR();
      allow write: if false;
    }

    // ── Outbound Communications Standard log (DTLK-STD-COMMS-001) ──
    // Append-only audit of every platform-sent message. Written ONLY by the
    // comms gateway (lib/comms-gateway.js) via the Admin SDK, which bypasses
    // these rules. No client may create, modify, or delete a row — so the
    // "no send without an immutable log entry" guarantee holds at the boundary.
    // Read for governance roles (CEO / Finance / HR-Compliance).
    match /outbound_comms_log/{messageRef} {
      allow read: if isCeo() || isFinance() || isHR();
      allow write: if false;
    }

    // ── Iqama lifecycle ──
    // iqama_records/{employee_id} holds the lifecycle state. Reads allowed
    // for any signed-in user (the employee should see their own dashboard
    // widget), but UPDATES only via the advanceIqamaStage Cloud Function
    // which enforces HR-only + writes the evidence row server-side.
    match /iqama_records/{empId} {
      allow read: if request.auth != null;
      allow write: if isCeo() || isHR();
      match /iqama_evidence/{evId} {
        allow read: if request.auth != null;
        allow create: if isCeo() || isHR();
        allow update, delete: if false;
      }
    }

    // ── Payroll runs ──
    // Salary is Tier-1 PII. NO blanket read. Segregation of duties between
    // preparer (finance/HR) and approver (CEO only). Employee payslip
    // access goes through the listMyPayslips Cloud Function (which checks
    // caller == subject from the auth token) — never via direct read.
    match /payroll_runs/{runId} {
      // Read: CEO/finance/HR see all. Employees do NOT read directly.
      allow read: if isCeo() || isFinance() || isHR();

      // Preparer: finance/HR/CEO may create the DRAFT.
      allow create: if isFinance() || isHR() || isCeo();

      // Preparer edits ONLY while DRAFT (DRAFT→DRAFT). The DRAFT→APPROVED flip is
      // NO LONGER client-writable — it is written ONLY by the recordApproval Cloud
      // Function (Admin SDK), which also writes the immutable evidence + WORM record.
      // This enforces segregation of duties server-side: no client SDK path, not even
      // the CEO's, can approve a payroll run directly.
      allow update: if (isFinance() || isHR())
        && resource.data.status == 'DRAFT'
        && request.resource.data.status == 'DRAFT';

      // No deletes.
      allow delete: if false;

      // Per-run approval evidence — written server-side only.
      match /approval_evidence/{evId} {
        allow read: if isCeo() || isFinance() || isHR();
        allow create, update, delete: if false;
      }
    }

    // Payroll deductions (one-off / installment). Read for CEO/finance/HR; all
    // writes go through the createDeduction/cancelDeduction Cloud Functions
    // (validation + audit + balance integrity) — never directly from a client.
    match /deductions/{deductionId} {
      allow read: if isCeo() || isFinance() || isHR();
      allow write: if false;
    }

    // ── CEO Dashboards ──
    match /ai_agents/{docId} { allow read, write: if isCeo(); }
    // Notifications — owner-scoped. A user only reads/writes their own
    // notifications (matched by user_email on the doc). Anyone signed in
    // may create a notification (system fan-outs frequently target other
    // users).
    match /notifications/{noteId} {
      allow read, write: if request.auth != null
        && request.auth.token.email == resource.data.user_email;
      allow create: if request.auth != null;
    }
    match /analytics/{docId} { allow read, write: if request.auth != null; }
    match /compliance/{docId} {
      // Compliance/CAPA register — feeds AuditExport. Read by GRC staff; write limited
      // to CEO/CTO (the SAMA materiality auto-create runs in a CEO/CTO context).
      allow read: if isCeoOrCto() || isHR() || isFinance();
      allow write: if isCeoOrCto();
    }
    match /pipeline/{docId} { allow read, write: if request.auth != null; }
    match /system_health/{docId} { allow read, write: if request.auth != null; }

    // ── System Counters ──
    match /counters/{docId} {
      allow read, write: if request.auth != null && (getUserRole() == "ceo" || getUserRole() == "hr");
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
