rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isCeoOrCto() {
      return request.auth != null && 
        (request.auth.token.email == "m.alqumri@datalake.sa" ||
         request.auth.token.email == "cto@datalake.sa");
    }
    
    function isCeo() {
      return request.auth != null && request.auth.token.email == "m.alqumri@datalake.sa";
    }

    function getUserRole() {
      return isCeo() ? "ceo" :
             (request.auth != null && (request.auth.token.email == "hr@datalake.sa" || request.auth.token.email == "HR@datalake.sa")) ? "hr" :
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role_id;
    }

    function isAssignedClient(clientId) {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.client_id == clientId;
    }

    // Role helpers. These match getUserRole()'s precedence (hardcoded HR
    // email → role_id from users doc). Used for the segregation-of-duties
    // rules on payroll, approval evidence, etc.
    function isHR() {
      return request.auth != null && (
        request.auth.token.email == "hr@datalake.sa" ||
        request.auth.token.email == "HR@datalake.sa" ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role_id == "hr"
      );
    }
    function isFinance() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role_id == "finance";
    }
    function isBusinessOrSales() {
      return request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role_id == "business" ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role_id == "sales"
      );
    }
    
    // ── RBAC Collections ──
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create, delete: if isCeo();
      // Only the CEO assigns roles — but CANNOT change their OWN role (segregation of duties).
      allow update: if isCeo() && (request.auth.uid != uid || request.resource.data.role_id == resource.data.role_id);
      // Employees may flip ONLY their own onboarding flags on their own user doc.
      // We match by Firebase Auth uid OR by email — legacy users docs are keyed by
      // employee_id (DLSA1003 etc) rather than uid, and the Onboarding flow looks
      // them up via the email fallback.
      allow update: if request.auth != null
        && (request.auth.uid == uid || request.auth.token.email == resource.data.email)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['onboarding_complete', 'onboarding_completed_at', 'pdpl_consent_state', 'pdpl_consent_at', 'pdpl_consent_ip', 'pdpl_consent_user_agent', 'training_completed', 'contract_signed']);
    }

    // ── Hire Chain ──
    match /pending_hires/{hireId} {
      // Reads allowed for any signed-in user, OR public token-gated read
      // when the hire still has an unconsumed client_hire_token (so the
      // /client/approve-hire/:token public page can render).
      allow read: if request.auth != null;
      allow read: if resource.data.client_hire_token != null;
      allow create, delete: if isCeo();
      // CEO can edit anything. Public client-PM token flow may set ONLY the
      // acknowledge/dispute audit fields if the hire still has a token.
      allow update: if isCeo();
      allow update: if resource.data.client_hire_token != null &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'client_acknowledged_at', 'client_acknowledged_by',
          'client_disputed_at', 'client_disputed_by',
          'client_action_ip', 'client_signature_method',
          'client_signature_image', 'client_signature_typed',
          'client_dispute_reason',
        ]);

      // Approval evidence subcollection — anyone signed in may write theirs;
      // the public client-PM token flow may also append an evidence row.
      match /approval_evidence/{evId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow create: if request.resource.data.token_used != null;
      }
    }

    // Token-gated client acknowledgement of a hire placement. Anyone with the
    // (cryptographically random) token URL may read it once; only CEO/HR
    // create/delete. The token is burned (deleted) by the client page on
    // submit, which is the only mutation we allow from unauthenticated users.
    match /client_hire_tokens/{token} {
      allow read: if true;
      allow create: if isCeo() || (request.auth != null && getUserRole() == "hr");
      allow delete: if true; // burn-after-use; safe because token is opaque
      allow update: if false;
    }

    // ── IT Administration (it_admin only) — segregated from role assignment ──
    match /admin_credentials/{docId} {
      allow read, write: if request.auth != null && getUserRole() == "it_admin";
    }
    match /password_policies/{docId} {
      allow read, write: if request.auth != null && getUserRole() == "it_admin";
    }
    match /roles/{roleId} {
      allow read: if request.auth != null;
      allow write: if isCeo();
    }
    match /access_matrix/{roleId} {
      allow read: if request.auth != null;
      allow write: if isCeo();
    }
    match /clients/{clientId} {
      // CEO sees all. Business/sales (CRM portal) read+write all client
      // metadata + status/pipeline_stage. A logged-in `client` user reads
      // only the client doc they're scoped to (kept from prior rule).
      allow read: if request.auth != null && (isCeo() || isBusinessOrSales() || isAssignedClient(clientId));
      allow write: if isCeo() || isBusinessOrSales();

      // Per-client notes timeline (CRM detail page Add Note). Same audience
      // as the parent doc; rows are append-only to preserve the interaction
      // log.
      match /client_notes/{noteId} {
        allow read: if isCeo() || isBusinessOrSales();
        allow create: if isCeo() || isBusinessOrSales();
        allow update, delete: if false;
      }
    }

    // ── Employees & HR ──
    match /employees/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (getUserRole() == "ceo" || getUserRole() == "hr");
      // CEO/HR may update any field. The employee who owns the record (matched by email)
      // may edit ONLY their own limited self-service fields.
      allow update: if request.auth != null && (
        getUserRole() == "ceo" || getUserRole() == "hr" ||
        (request.auth.token.email == resource.data.email &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['phone', 'emergency_contact', 'photo_url', 'skills', 'certifications', 'updated_at', 'onboarding_complete', 'onboarding_completed_at', 'pdpl_consent_state', 'pdpl_consent_at']))
      );
      allow delete: if request.auth != null && (getUserRole() == "ceo" || (getUserRole() == "hr" && resource.data.employment_status == "PENDING_APPROVAL"));

      // Onboarding acknowledgments: an employee writes their own ack docs
      // (each stamped with their email; reads allowed for any signed-in user / HR/CEO).
      match /onboarding/{itemId} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null
          && request.resource.data.employee_email == request.auth.token.email;
      }
      match /onboarding_evidence/{policyId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
      }
    }
    match /talent_pool/{candidateId} {
      allow read, write: if isCeo() || (request.auth != null && getUserRole() == "hr");
    }
    match /job_listings/{jobId} {
      allow read: if true;
      allow write: if isCeo() || (request.auth != null && getUserRole() == "hr");
    }
    match /employee_documents/{docId} {
      allow read, write: if request.auth != null;
    }
    match /document_requests/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (getUserRole() == "ceo" || getUserRole() == "hr");
    }
    match /training_modules/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (getUserRole() == "ceo" || getUserRole() == "hr");
    }
    match /training_completions/{docId} {
      allow read, write: if request.auth != null;
    }
    match /leave_requests/{docId} {
      allow read, write: if request.auth != null;
    }
    match /leave_balances/{docId} {
      allow read, write: if request.auth != null;
    }
    match /expenses/{docId} {
      allow read, write: if request.auth != null;
    }
    match /travel_requests/{docId} {
      allow read, write: if request.auth != null;
    }

    // ── Projects & Timesheets ──
    match /projects/{projectId} {
      allow read: if request.auth != null;
      allow write: if isCeoOrCto();
    }
    match /client_projects/{projectId} {
      allow read: if request.auth != null;
      allow write: if isCeoOrCto();
    }
    match /engineer_project_assignments/{assignmentId} {
      allow read: if request.auth != null;
      allow write: if isCeoOrCto();
    }
    match /timesheets/{timesheetId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if isCeo();
      allow update: if isCeoOrCto() || (
        request.resource.data.state == 'CLIENT_SIGNED' &&
        resource.data.state == 'CTO_APPROVED' &&
        resource.data.client_sign_token != null
      );

      // Immutable approval snapshot rows (written server-side by ctoApproveTimesheet
      // via the Admin SDK, which bypasses these rules). Readable by any signed-in
      // user for audit; never client-mutable — this is the regulator-facing record.
      match /approval_evidence/{evId} {
        allow read: if request.auth != null;
        allow create: if isCeoOrCto();
        allow update, delete: if false;
      }
    }

    // ── Finance & Operations ──
    match /invoices/{docId} {
      // SoD: invoices are READ-ONLY to clients. Every mutation (create via
      // generateInvoice, status flip via ceoApproveInvoice, PAID via the Zoho
      // webhook, Zoho/ZATCA stamps) runs in Cloud Functions on the Admin SDK,
      // which bypasses these rules. No client can flip an invoice's status itself.
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /client_invoices/{docId} {
      allow read, write: if request.auth != null;
    }
    match /finance_notifications/{notifId} {
      allow read, write: if request.auth != null;
    }
    match /contracts/{docId} {
      allow read, write: if request.auth != null;
    }
    // AI auditor proposal/contract review trail (written server-side; CEO-managed).
    match /proposal_reviews/{docId} {
      allow read: if request.auth != null;
      allow write: if isCeo();
    }

    // ── Operations & Support ──
    match /tasks/{taskId} {
      allow read, write: if request.auth != null;
    }
    match /task_audit_log/{logId} {
      allow read, write: if request.auth != null;
    }
    match /support_tickets/{docId} {
      allow read, write: if request.auth != null;
    }
    match /pending_approvals/{docId} {
      // SoD Hub queue: rows are created by generateInvoice and cleared by
      // ceoApproveInvoice (both Admin SDK). Read-only to clients so the queue
      // can't be emptied without the CEO actually approving via the function.
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /evaluations/{evalId} {
      allow read, write: if request.auth != null;
    }
    match /audit_log/{logId} {
      allow read, write: if request.auth != null;
    }
    match /client_profile/{docId} {
      allow read: if true;
      allow write: if isCeo();
    }

    // ── Engineer specific collections ──
    match /engineer_dashboard/{docId} {
      allow read, write: if request.auth != null;
    }
    match /engineer_actions/{docId} {
      allow read, write: if request.auth != null;
    }

    // ── Platform settings (SAMA criteria, finance_integrations, etc.) ──
    // Read for any signed-in user (components load criteria / toggles on
    // every mount). Writes are CEO-only.
    match /platform_settings/{docId} {
      allow read: if request.auth != null;
      allow write: if isCeo();
    }

    // ── HR email log ──
    // Read for HR / Finance / CEO (audit + send-history view). Writes go
    // through the sendHrEmail Cloud Function, never the client — direct
    // creates are blocked so the log can't be forged or amended.
    match /email_log/{logId} {
      allow read: if isCeo() || isFinance() || isHR();
      allow write: if false;
    }

    // ── Iqama lifecycle ──
    // iqama_records/{employee_id} holds the lifecycle state. Reads allowed
    // for any signed-in user (the employee should see their own dashboard
    // widget), but UPDATES only via the advanceIqamaStage Cloud Function
    // which enforces HR-only + writes the evidence row server-side.
    match /iqama_records/{empId} {
      allow read: if request.auth != null;
      allow write: if isCeo() || isHR();
      match /iqama_evidence/{evId} {
        allow read: if request.auth != null;
        allow create: if isCeo() || isHR();
        allow update, delete: if false;
      }
    }

    // ── Payroll runs ──
    // Salary is Tier-1 PII. NO blanket read. Segregation of duties between
    // preparer (finance/HR) and approver (CEO only). Employee payslip
    // access goes through the listMyPayslips Cloud Function (which checks
    // caller == subject from the auth token) — never via direct read.
    match /payroll_runs/{runId} {
      // Read: CEO/finance/HR see all. Employees do NOT read directly.
      allow read: if isCeo() || isFinance() || isHR();

      // Preparer: finance/HR/CEO may create the DRAFT.
      allow create: if isFinance() || isHR() || isCeo();

      // Preparer edits ONLY while DRAFT, and cannot flip to APPROVED here.
      allow update: if (isFinance() || isHR())
        && resource.data.status == 'DRAFT'
        && request.resource.data.status == 'DRAFT';

      // Approver: ONLY the CEO can transition DRAFT → APPROVED.
      // (CEO can also continue to edit a DRAFT — covered by the create/update
      // branches via isCeo() being inside isFinance() OR through this rule.)
      allow update: if isCeo()
        && resource.data.status == 'DRAFT'
        && request.resource.data.status == 'APPROVED';

      // No deletes.
      allow delete: if false;

      // Per-run approval evidence — CEO only, immutable.
      match /approval_evidence/{evId} {
        allow read: if isCeo() || isFinance() || isHR();
        allow create: if isCeo();
        allow update, delete: if false;
      }
    }

    // ── CEO Dashboards ──
    match /ai_agents/{docId} { allow read, write: if isCeo(); }
    // Notifications — owner-scoped. A user only reads/writes their own
    // notifications (matched by user_email on the doc). Anyone signed in
    // may create a notification (system fan-outs frequently target other
    // users).
    match /notifications/{noteId} {
      allow read, write: if request.auth != null
        && request.auth.token.email == resource.data.user_email;
      allow create: if request.auth != null;
    }
    match /analytics/{docId} { allow read, write: if request.auth != null; }
    match /compliance/{docId} { allow read, write: if request.auth != null; }
    match /pipeline/{docId} { allow read, write: if request.auth != null; }
    match /system_health/{docId} { allow read, write: if request.auth != null; }

    // ── System Counters ──
    match /counters/{docId} {
      allow read, write: if request.auth != null && (getUserRole() == "ceo" || getUserRole() == "hr");
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
