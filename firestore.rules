rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isCeoOrCto() {
      return request.auth != null && 
        (request.auth.token.email == "m.alqumri@datalake.sa" ||
         request.auth.token.email == "cto@datalake.sa");
    }
    
    function isCeo() {
      return request.auth != null && request.auth.token.email == "m.alqumri@datalake.sa";
    }

    function getUserRole() {
      return isCeo() ? "ceo" :
             (request.auth != null && (request.auth.token.email == "hr@datalake.sa" || request.auth.token.email == "HR@datalake.sa")) ? "hr" :
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role_id;
    }

    function isAssignedClient(clientId) {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.client_id == clientId;
    }
    
    // ── RBAC Collections ──
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if isCeo();
    }
    match /roles/{roleId} {
      allow read: if request.auth != null;
      allow write: if isCeo();
    }
    match /access_matrix/{roleId} {
      allow read: if request.auth != null;
      allow write: if isCeo();
    }
    match /clients/{clientId} {
      allow read: if request.auth != null && (isCeo() || isAssignedClient(clientId));
      allow write: if isCeo();
    }

    // ── Employees & HR ──
    match /employees/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (getUserRole() == "ceo" || getUserRole() == "hr");
      allow update: if request.auth != null && (getUserRole() == "ceo" || getUserRole() == "hr" || request.auth.token.email == resource.data.email);
      allow delete: if request.auth != null && (getUserRole() == "ceo" || (getUserRole() == "hr" && resource.data.employment_status == "PENDING_APPROVAL"));
    }
    match /talent_pool/{candidateId} {
      allow read, write: if isCeo() || (request.auth != null && getUserRole() == "hr");
    }
    match /job_listings/{jobId} {
      allow read: if true;
      allow write: if isCeo() || (request.auth != null && getUserRole() == "hr");
    }
    match /employee_documents/{docId} {
      allow read, write: if request.auth != null;
    }
    match /document_requests/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (getUserRole() == "ceo" || getUserRole() == "hr");
    }
    match /training_modules/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (getUserRole() == "ceo" || getUserRole() == "hr");
    }
    match /training_completions/{docId} {
      allow read, write: if request.auth != null;
    }
    match /leave_requests/{docId} {
      allow read, write: if request.auth != null;
    }
    match /expenses/{docId} {
      allow read, write: if request.auth != null;
    }
    match /travel_requests/{docId} {
      allow read, write: if request.auth != null;
    }

    // ── Projects & Timesheets ──
    match /projects/{projectId} {
      allow read: if request.auth != null;
      allow write: if isCeoOrCto();
    }
    match /client_projects/{projectId} {
      allow read: if request.auth != null;
      allow write: if isCeoOrCto();
    }
    match /engineer_project_assignments/{assignmentId} {
      allow read: if request.auth != null;
      allow write: if isCeoOrCto();
    }
    match /timesheets/{timesheetId} {
      allow read, update: if request.auth != null;
      allow create, delete: if isCeoOrCto() || request.auth != null;
    }

    // ── Finance & Operations ──
    match /invoices/{docId} {
      allow read, write: if request.auth != null;
    }
    match /client_invoices/{docId} {
      allow read, write: if request.auth != null;
    }
    match /finance_notifications/{notifId} {
      allow read, write: if request.auth != null;
    }
    match /contracts/{docId} {
      allow read, write: if request.auth != null;
    }

    // ── Operations & Support ──
    match /tasks/{taskId} {
      allow read, write: if request.auth != null;
    }
    match /task_audit_log/{logId} {
      allow read, write: if request.auth != null;
    }
    match /support_tickets/{docId} {
      allow read, write: if request.auth != null;
    }
    match /pending_approvals/{docId} {
      allow read, write: if request.auth != null;
    }
    match /evaluations/{evalId} {
      allow read, write: if request.auth != null;
    }
    match /audit_log/{logId} {
      allow read, write: if request.auth != null;
    }
    match /client_profile/{docId} {
      allow read: if true;
      allow write: if isCeo();
    }

    // ── Engineer specific collections ──
    match /engineer_dashboard/{docId} {
      allow read, write: if request.auth != null;
    }
    match /engineer_actions/{docId} {
      allow read, write: if request.auth != null;
    }

    // ── CEO Dashboards ──
    match /ai_agents/{docId} { allow read, write: if isCeo(); }
    match /notifications/{docId} { allow read, write: if request.auth != null; }
    match /analytics/{docId} { allow read, write: if request.auth != null; }
    match /compliance/{docId} { allow read, write: if request.auth != null; }
    match /pipeline/{docId} { allow read, write: if request.auth != null; }
    match /system_health/{docId} { allow read, write: if request.auth != null; }

    // ── System Counters ──
    match /counters/{docId} {
      allow read, write: if request.auth != null && (getUserRole() == "ceo" || getUserRole() == "hr");
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
